# ============================================================
# BAJIE IoT Platform — App API (Public/User layer)
# ============================================================
BAJIE_APP_BASE_URL=https://m.voltajevzla.com/cdb-app-api/v1/app
BAJIE_ADMIN_BASE_URL=https://m.voltajevzla.com/cdb-web-api/v1

# ============================================================
# BAJIE IoT Platform — Admin API (Operator layer)
# These tokens come from the Bajie admin panel session.
# They may expire and need refreshing.
# ============================================================
BAJIE_ADMIN_TOKEN=<your-bajie-admin-token>
BAJIE_ADMIN_JSESSIONID=<your-bajie-jsessionid>

# ============================================================
# BNC Payment Gateway (Production)
# ============================================================
BNC_API_URL=https://servicios.bncenlinea.com:16100/api
BNC_CLIENT_GUID=<your-bnc-client-guid>
BNC_MASTER_KEY=<your-bnc-master-key>
BNC_ACCOUNT_NUMBER=<your-bnc-account-number>
BNC_CLIENT_ID=<your-bnc-client-id>
BNC_AFFILIATE=<your-bnc-affiliate>
BNC_TERMINAL=<your-bnc-terminal>
BNC_MERCHANT_PHONE=<your-merchant-phone>

# ============================================================
# CASHEA Payment Gateway (Sandbox/Pruebas)
# ============================================================
CASHEA_PUBLIC_API_KEY=<your-cashea-public-key>
CASHEA_PRIVATE_API_KEY=<your-cashea-private-key>
CASHEA_STORE_ID=<your-cashea-store-id>
CASHEA_STORE_NAME=<your-cashea-store-name>
CASHEA_EXTERNAL_CLIENT_ID=<your-cashea-external-client-id>
CASHEA_SANDBOX=true

# ============================================================
# NOTIFICATIONS (Email SMTP and WhatsApp Whapi)
# ============================================================
EMAIL_USER=<your-email@gmail.com>
EMAIL_PASS=<your-app-password>
WHAPI_TOKEN=<your-whapi-token>
WHAPI_URL=https://gate.whapi.cloud/messages/text
