# ============================================================
# Firebase Configuration
# ============================================================
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_PRIVATE_KEY=<your-firebase-private-key>
FIREBASE_CLIENT_EMAIL=<your-firebase-client-email>

# ============================================================
# BAJIE IoT Platform — OpenAPI (New Official Method)
# ============================================================
BAJIE_OPENAPI_URL=https://m.voltajevzla.com/cdb-open-api/v1
BAJIE_ACCOUNT=<your-bajie-account>
BAJIE_PASSWORD=<your-bajie-password>

# ============================================================
# BAJIE IoT Platform — App API (Legacy/User layer)
# ============================================================
BAJIE_APP_BASE_URL=https://m.voltajevzla.com/cdb-app-api/v1/app
BAJIE_ADMIN_BASE_URL=https://m.voltajevzla.com/cdb-web-api/v1

# ============================================================
# BAJIE IoT Platform — Admin API (Legacy Operator layer)
# ============================================================
BAJIE_ADMIN_TOKEN=<your-bajie-admin-token>
BAJIE_ADMIN_JSESSIONID=<your-bajie-jsessionid>
LEGACY_ADMIN_TOKEN=<your-legacy-admin-token>
LEGACY_COOKIE_FULL="JSESSIONID=<jsessionid>; token=<token>"

# ============================================================
# BNC Payment Gateway
# ============================================================
BNC_API_URL=https://servicios.bncenlinea.com:16100/api
BNC_CLIENT_GUID=<your-bnc-client-guid>
BNC_MASTER_KEY=<your-bnc-master-key>
BNC_ACCOUNT_NUMBER=<your-bnc-account-number>
BNC_CLIENT_ID=<your-bnc-client-id>
BNC_AFFILIATE=<your-bnc-affiliate>
BNC_TERMINAL=<your-bnc-terminal>
BNC_MERCHANT_PHONE=<your-merchant-phone>
