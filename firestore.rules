rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Active rentals: ONLY admin can read
    match /active_rentals/{rentalId} {
      allow read: if request.auth != null
                  && request.auth.token.email == 'ezequielrodriguez1991@gmail.com';
      allow write: if false; // Only Cloud Functions write here
    }

    // GPS tracking logs: ONLY admin can read all, users can write their own
    match /gps_tracking/{trackingId} {
      allow read: if request.auth != null
                  && request.auth.token.email == 'ezequielrodriguez1991@gmail.com';
      allow write: if request.auth != null;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Rental history
    match /rental_history/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions write here
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
